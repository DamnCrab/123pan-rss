{
  "name": "server",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "build-frontend": "cd ../client && bun install && bun run build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy-with-frontend": "npm run build-frontend && wrangler deploy --minify",
    "database:generate": "drizzle-kit generate",
    "database:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-validator": "^0.7.0",
    "@scalar/hono-api-reference": "^0.9.6",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.2",
    "hono-openapi": "^0.4.8",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.67",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1",
    "wrangler": "^4.4.0"
  }
}
